<!DOCTYPE html>
<html lang="{{@root.site.locale}}">
<head>

    {{!-- Basic meta - advanced meta is output with {{ghost_head}} below --}}
    <title>{{meta_title}}</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    {{!-- Preload main styles and scripts for better performance --}}
    <link rel="preload" as="style" href="{{asset "built/screen.css"}}">
    <link rel="preload" as="script" href="{{asset "built/source.js"}}">
    
    {{!-- Fonts are preloaded and defined in the default template to avoid layout shift --}}
    {{> partials/typography/fonts}}

    {{!-- Theme assets - use the {{asset}} helper to reference styles & scripts, this will take care of caching and cache-busting automatically --}}
    <link rel="stylesheet" type="text/css" href="{{asset "built/screen.css"}}">
    <link rel="stylesheet" href="{{asset "css/font-awesome.min.css"}}">

    {{!-- Custom background color --}}
    <style>
        :root {
            --background-color: {{@root.custom.site_background_color}}
        }
    </style>

    <script>
        /* The script for calculating the color contrast has been taken from
        https://gomakethings.com/dynamically-changing-the-text-color-based-on-background-color-contrast-with-vanilla-js/ */
        var accentColor = getComputedStyle(document.documentElement).getPropertyValue('--background-color');
        accentColor = accentColor.trim().slice(1);

        if (accentColor.length === 3) {
            accentColor = accentColor[0] + accentColor[0] + accentColor[1] + accentColor[1] + accentColor[2] + accentColor[2];
        }

        var r = parseInt(accentColor.substr(0, 2), 16);
        var g = parseInt(accentColor.substr(2, 2), 16);
        var b = parseInt(accentColor.substr(4, 2), 16);
        var yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
        var textColor = (yiq >= 128) ? 'dark' : 'light';

        document.documentElement.className = `has-${textColor}-text`;
    </script>

    {{!-- This tag outputs all your advanced SEO meta, structured data, and other important settings, it should always be the last tag before the closing head tag --}}
    {{ghost_head}}

    <script
        src="https://code.jquery.com/jquery-3.5.1.min.js"
        integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
        crossorigin="anonymous">
    </script>
</head>
<body class="{{body_class}} has-{{#match @root.custom.title_font "Elegant serif"}}serif{{else match @root.custom.title_font "Consistent mono"}}mono{{else}}sans{{/match}}-title has-{{#match @root.custom.body_font "Elegant serif"}}serif{{else}}sans{{/match}}-body">

<div class="gh-viewport">
    
    {{> partials/components/navigation navigationLayout=@root.custom.navigation_layout}}

    {{~> body}}
    
    {{> partials/components/footer}}
    
</div>

{{#is "post, page"}}
    {{> partials/lightbox}}
{{/is}}

{{!-- Scripts - handle responsive videos, infinite scroll, and navigation dropdowns --}}
<script src="{{asset "built/source.js"}}"></script>

<style>
    .cartanza-cart-container {
        position: relative;
    }
    .cartanza-header-cart {
        right: 0 !important;
        top: 100% !important;
    }
    @media (max-width: 767px) {
        .cartanza-header-cart {
            display: none !important;
        }
    }
</style>

<script>
    // Select the cart icon and header cart elements
    const cartIcon = document.querySelector('i.fs-12.fa.fa-shopping-bag');
    if(cartIcon) {
        const headerCart = document.querySelector('div.cartanza-header-cart');

        document.addEventListener('click', (event) => {
            if (cartIcon.contains(event.target)) {
                if (window.innerWidth < 768) {
                    window.location.href = '/cart';
                } else {
                    headerCart.classList.toggle('show-header-dropdown');
                }
            } else if (!headerCart.contains(event.target)) {
                headerCart.classList.remove('show-header-dropdown');
            }
        });
        window.onload = function() {
            getCart();
        }
    }
</script>
<script>
    let wasInPortal = window.location.hash.includes('/portal/');

    function checkPortal() {
        const isInPortal = window.location.hash.includes('/portal/');
        if (isInPortal) {
            wasInPortal = true;
        } else if (wasInPortal) {
            wasInPortal = false;
            window.location.reload();
        }
    }

    window.addEventListener('hashchange', () => {
        checkPortal();
    });
    
    // Ghost Portal often uses history.replaceState to close, which doesn't trigger hashchange.
    // We check the hash every 500ms while we believe the portal is open.
    setInterval(checkPortal, 500);

    async function logout(event) {
        event.preventDefault();
        try {
            const response = await fetch('/members/api/session/', {
                method: 'DELETE', // HTTP method
                headers: {
                    'Content-Type': 'application/json' // Specify JSON payload
                },
                body: JSON.stringify({ all: false }) // Convert the data to JSON string
            });

            if (response.ok) {
                console.log('Session logged out successfully');
                window.location.href = '/';
            } else {
                console.error('Failed to logout of session:', response.status, response.statusText);
            }
        } catch (error) {
            console.error('Error:', error);
        }
    }
</script>
{{!-- Ghost outputs required functional scripts with this tag, it should always be the last thing before the closing body tag --}}
{{ghost_foot}}

</body>
</html>
