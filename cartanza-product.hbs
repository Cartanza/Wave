{{#*inline "body"}}
<style>
.cartanza-product-container {
    display: flex;
    justify-content: space-between;
    margin: auto;
    margin-top: 10%;
    max-width: var(--container-width, 1200px);
    width: 100%;
}
.cartanza-product-image-gallery {
    display: flex;
    width: 50%;
}
.cartanza-product-image-picker-container {
    width: 25%;
    margin-right: 15px;
}
.cartanza-product-image-picker-container ul {
    list-style-type: none;
    margin-top: 0;
    padding-left: 0;
    max-height: 550px;
    overflow-y: auto;
}
.cartanza-product-image-picker-container ul::-webkit-scrollbar {
    width: 4px;
}
.cartanza-product-image-picker-container ul::-webkit-scrollbar-thumb {
    background: #ccc;
    border-radius: 4px;
}
.cartanza-product-thumbnail {
    margin-bottom: 5px;
    cursor: pointer;
    border: 3px solid transparent;
    margin-top: 0;
}
.cartanza-product-thumbnail img {
    width: 100%;
    display: block;
}
.cartanza-product-image-target-container {
    width: 75%;
}
.cartanza-product-image-target-container img {
    width: 100%;
    display: block;
}
.cartanza-product-description-container {
    padding: 20px;
    width: 50%;
}

@media (max-width: 767px) {
    .cartanza-product-container {
        flex-direction: column;
        margin-top: 20px;
        padding: 0 15px;
    }
    .cartanza-product-image-gallery {
        flex-direction: column-reverse;
        width: 100%;
    }
    .cartanza-product-image-picker-container {
        width: 100%;
        margin-right: 0;
        margin-top: 10px;
    }
    .cartanza-product-image-picker-container ul {
        display: flex;
        flex-direction: row;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        max-height: none;
        padding-bottom: 5px;
    }
    .cartanza-product-thumbnail {
        display: inline-block;
        width: 60px;
        height: 60px;
        margin-bottom: 0;
        margin-right: 8px;
        flex-shrink: 0;
        margin-top: 0;
    }
    .cartanza-product-thumbnail img {
        height: 100%;
        object-fit: cover;
    }
    .cartanza-product-image-target-container {
        width: 100%;
    }
    .cartanza-product-description-container {
        width: 100%;
        padding: 15px 0;
    }
}
</style>

{{!-- The tag above means: insert everything in this file
into the {body} tag of the default.hbs template --}}

{{#with cartanza_product}}
    <div class="cartanza-product-container">
        <div class="cartanza-product-image-gallery">
            <div class="cartanza-product-image-picker-container">
            <ul id="product-image-picker">
            {{#foreach images}}
                <li class="cartanza-product-thumbnail" role="" style="{{#if (eq @index 0) }}border: 3px solid #888888;{{/if}}">
                    <img class="" src="{{product_image_url src}}" alt="{{alt}}">
                    <div class=""></div>
                </li>
            {{/foreach}}
            </ul>
            </div>
            <div class="cartanza-product-image-target-container">
                <img class="" src="{{product_image_url (img_url images.[0].src)}}" alt="{{tittle}}" id="product-image-target">
            </div>
        </div>
        <div class="cartanza-product-description-container">
            <h4 class="">
                {{ title }}
            </h4>
            <span id="" class="">
                <span class=""><span class="money">{{formatPrice variants.[0].price site.commerce_currency}}</span></span>
            </span>
            <p>{{{description}}}</p>
            {{#if event}}
                <br/>
                {{#foreach variants}}
                    <p>
                        {{#if (or (gt inventory_quantity 0) (eq inventory_policy "allow"))}}
                            {{#if optiononevalue.value}}
                                {{ optiononevalue.value }}
                            {{else}}
                                {{../title}}
                            {{/if}}
                            {{#if optiontwovalue.value}}
                                / {{ optiontwovalue.value }}
                            {{/if}}
                            {{#if optionthreevalue.value}}
                                / {{ optionthreevalue.value }}
                            {{/if}}
                        {{ else }}
                            {{#if optiononevalue.value}}
                                {{ optiononevalue.value }}
                            {{else}}
                                {{../title}}
                            {{/if}}
                            {{#if optiontwovalue.value}}
                                / {{ optiontwovalue.value }}
                            {{/if}}
                            {{#if optionthreevalue.value}}
                                / {{ optionthreevalue.value }}
                            {{/if}} - Sold out
                        {{/if}}
                    </p>
                    <p>
                        Starts: {{ date starts_at format="MMMM D, YYYY at h:mm A" }}<br/>
                        Ends: {{ date ends_at format="MMMM D, YYYY at h:mm A" }}<br/>
                    </p>
                {{/foreach}}
            {{/if}}
            <div class="cartanza-product-form-container">
                <form action="/cart/add" method="post" enctype="multipart/form-data" id="form_buy">
                <div class="cartanza-product-form-select-container" style="margin: 20px;border: 1px solid #e6e6e6 !important;border-radius: 2px;">
                    <select name="id" id="variant-selector" class="form-control" style="display: block;width: 100%;padding: .5rem .75rem;color: #495057;border:1px solid rgba(0, 0, 0, .15);border-radius:.25rem;">
                        {{#foreach variants}}
                        {{#if (or (gt inventory_quantity 0) (eq inventory_policy "allow"))}}
                        <option data-sku="{{ sku }}" value="{{ id }}" data-image="{{product_image_url image_src}}">
                            {{#if optiononevalue.value}}
                                {{ optiononevalue.value }}
                            {{else}}
                                {{../title}}
                            {{/if}}
                            {{#if optiontwovalue.value}}
                                / {{ optiontwovalue.value }}
                            {{/if}}
                            {{#if optionthreevalue.value}}
                                / {{ optionthreevalue.value }}
                            {{/if}}
                             - {{ formatPrice price site.commerce_currency }}
                        </option>
                        {{ else }}
                        <option disabled="disabled">
                            {{#if optiononevalue.value}}
                                {{ optiononevalue.value }}
                            {{else}}
                                {{../title}}
                            {{/if}}
                            {{#if optiontwovalue.value}}
                                / {{ optiontwovalue.value }}
                            {{/if}}
                            {{#if optionthreevalue.value}}
                                / {{ optionthreevalue.value }}
                            {{/if}} - Sold out
                        </option>
                        {{/if}}
                        {{/foreach}}
                    </select>
                </div>
                <div class="cartanza-product-form-button-container">
                    <div class="cartanza-product-quantity-container" style="margin:20px;display:flex;align-items:center;">
                        <div class="cartanza-product-input-container" style="border:2px solid #e6e6e6;border-radius: 3px;">
                            <button type="button" class="" id="button-minus" style="width:42px;height:44px;">
                                <i class="fs-12 fa fa-minus" aria-hidden="true" style="color:#666666;"></i>
                            </button>
                            <input class="" type="text" id="input-quantity" name="quantity" value="1" style="color:#666666;outline:none;border:none;width:50px;height:42px;text-align:center;">
                            <button type="button" class="" id="button-plus" style="width:42px;height:44px;">
                                <i class="fs-12 fa fa-plus" aria-hidden="true" style="color:#666666;"></i>
                            </button>
                        </div>
                        <div class="cartanza-product-add-to-cart-button-container" style="margin: 20px;">
                            <button class="cartanza-product-add-to-cart-button" type="button" name="add" id="button-cart" style="border-radius:20px;background-color:#222222;align-items: center;color: white;text-transform:uppercase;padding:12px 20px;">ADD TO CART</button>
                        </div>
                    </div>
                </div>
                </form>
            </div>
        </div>
    </div>
{{/with}}
<script>
document.addEventListener('DOMContentLoaded', function() {
    registerProductImagePicker('product-image-picker','product-image-target');
    registerVariantSelector('variant-selector', 'product-image-target');
    registerQuantityButton('button-minus','button-plus', 'input-quantity');
    registerAddToCartButton('button-cart');

    // Create dynamic lightbox modal
    const modal = document.createElement('div');
    modal.id = 'cartanza-lightbox-modal';
    modal.style.cssText = `
        position: fixed;
        z-index: 999999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.75);
        display: none;
        justify-content: center;
        align-items: center;
        user-select: none;
    `;

    const closeBtn = document.createElement('span');
    closeBtn.innerHTML = '&times;';
    closeBtn.style.cssText = `
        position: absolute;
        top: 20px;
        right: 30px;
        color: #fff;
        font-size: 40px;
        font-weight: bold;
        cursor: pointer;
        z-index: 1000000;
    `;

    const btnStyle = `
        position: absolute;
        color: #fff;
        font-size: 24px;
        font-weight: bold;
        cursor: pointer;
        z-index: 1000000;
        background: rgba(0, 0, 0, 0.4);
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease;
        user-select: none;
    `;

    const prevBtn = document.createElement('span');
    prevBtn.innerHTML = '&#10094;';
    prevBtn.style.cssText = btnStyle + "left: 20px;";

    const nextBtn = document.createElement('span');
    nextBtn.innerHTML = '&#10095;';
    nextBtn.style.cssText = btnStyle + "right: 20px;";

    // Hover transitions for navigation buttons
    prevBtn.onmouseenter = () => prevBtn.style.backgroundColor = 'rgba(0,0,0,0.75)';
    prevBtn.onmouseleave = () => prevBtn.style.backgroundColor = 'rgba(0,0,0,0.4)';
    nextBtn.onmouseenter = () => nextBtn.style.backgroundColor = 'rgba(0,0,0,0.75)';
    nextBtn.onmouseleave = () => nextBtn.style.backgroundColor = 'rgba(0,0,0,0.4)';

    const imgContainer = document.createElement('div');
    imgContainer.style.cssText = `
        max-width: 85%;
        max-height: 85%;
        display: flex;
        justify-content: center;
        align-items: center;
    `;

    const lightboxImg = document.createElement('img');
    lightboxImg.style.cssText = `
        max-width: 100%;
        max-height: 90vh;
        object-fit: contain;
    `;

    imgContainer.appendChild(lightboxImg);
    modal.appendChild(closeBtn);
    modal.appendChild(prevBtn);
    modal.appendChild(nextBtn);
    modal.appendChild(imgContainer);
    document.body.appendChild(modal);

    let currentIndex = 0;
    const targetImg = document.getElementById('product-image-target');

    if (targetImg) {
        targetImg.style.cursor = 'pointer';
        targetImg.addEventListener('click', () => {
            const currentSrc = targetImg.src;
            const imageUrls = Array.from(document.querySelectorAll('#product-image-picker img')).map(img => img.src);
            currentIndex = imageUrls.indexOf(currentSrc);
            if (currentIndex === -1) currentIndex = 0;
            
            updateLightbox(imageUrls);
            modal.style.display = 'flex';
        });
    }

    function updateLightbox(imageUrls) {
        lightboxImg.src = imageUrls[currentIndex];
        if (imageUrls.length <= 1) {
            prevBtn.style.display = 'none';
            nextBtn.style.display = 'none';
        } else {
            prevBtn.style.display = 'flex';
            nextBtn.style.display = 'flex';
        }
    }

    function showNext() {
        const imageUrls = Array.from(document.querySelectorAll('#product-image-picker img')).map(img => img.src);
        if (imageUrls.length > 0) {
            currentIndex = (currentIndex + 1) % imageUrls.length;
            updateLightbox(imageUrls);
        }
    }

    function showPrev() {
        const imageUrls = Array.from(document.querySelectorAll('#product-image-picker img')).map(img => img.src);
        if (imageUrls.length > 0) {
            currentIndex = (currentIndex - 1 + imageUrls.length) % imageUrls.length;
            updateLightbox(imageUrls);
        }
    }

    nextBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        showNext();
    });

    prevBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        showPrev();
    });

    closeBtn.addEventListener('click', () => {
        modal.style.display = 'none';
    });

    modal.addEventListener('click', (e) => {
        if (e.target === modal || e.target === imgContainer) {
            modal.style.display = 'none';
        }
    });

    // Touch swipe navigation for mobile
    let touchStartX = 0;
    let touchEndX = 0;

    imgContainer.addEventListener('touchstart', e => {
        touchStartX = e.changedTouches[0].screenX;
    }, {passive: true});

    imgContainer.addEventListener('touchend', e => {
        touchEndX = e.changedTouches[0].screenX;
        handleSwipe();
    }, {passive: true});

    function handleSwipe() {
        const swipeThreshold = 50;
        if (touchEndX < touchStartX - swipeThreshold) {
            showNext();
        } else if (touchEndX > touchStartX + swipeThreshold) {
            showPrev();
        }
    }

    // Keyboard controls
    document.addEventListener('keydown', (e) => {
        if (modal.style.display === 'flex') {
            if (e.key === 'ArrowRight') {
                showNext();
            } else if (e.key === 'ArrowLeft') {
                showPrev();
            } else if (e.key === 'Escape') {
                modal.style.display = 'none';
            }
        }
    });
});
</script>
{{/inline}}
{{> default}}