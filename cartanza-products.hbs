{{#*inline "body"}}
{{!-- The tag above means: insert everything in this file
into the {body} tag of the default.hbs template --}}

{{#with products}}

    <section class="article-header gh-canvas" data-animate="fade" style="margin-bottom: 30px;">
        <div class="" style="position: relative;text-align: center;z-index: 2;">
            <h1 class="m-hero-title bigger">{{title}}</h1>
            <h2>{{{description}}}</h2>
        </div>
    </section>

    <div class="cartanza-collection-grid">
    {{#foreach products}}
    <div class="cartanza-collection-card">
        {{#link href=(concat '/products/' slug '/') activeClass="current"}}
        <div class="cartanza-collection-card-picture">
            <img class="cartanza-collection-card-picture-background" src="{{product_image_url (img_url images.[0].src)}}" width="183" loading="lazy" alt="{{title}}">
        </div>
        <div class="cartanza-collection-card-info">
            <div>
                <h2 class="cartanza-collection-card-title" title="{{title}}" style="margin:0em;">
                {{title}}
                </h2>
            </div>
            <div class="cartanza-collection-card-description">
                {{{truncate description 80}}}
            </div>
            <div class="cartanza-collection-card-price" style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px;">
                <span class="money" style="font-weight: 700; font-size: 1.6rem; color: var(--ghost-accent-color, #15171a);">
                    {{formatPrice variants.[0].price @root.site.commerce_currency}}
                </span>
                <div style="display: flex; gap: 6px;">
                    {{#if event}}
                        <span class="badge" style="background-color: var(--color-wash, #e5eff5); color: var(--color-darkgrey, #15171a); padding: 2px 8px; border-radius: 4px; font-size: 1.1rem; font-weight: 600; text-transform: uppercase;">Event</span>
                    {{/if}}
                    {{#with variants.[0]}}
                        {{#unless (or (gt inventory_quantity 0) (eq inventory_policy "allow"))}}
                            <span class="badge sold-out" style="background-color: #f05230; color: white; padding: 2px 8px; border-radius: 4px; font-size: 1.1rem; font-weight: 600; text-transform: uppercase;">Sold Out</span>
                        {{/unless}}
                    {{/with}}
                </div>
            </div>
        </div>
        {{/link}}
    </div>
    {{/foreach}}
    </div>

    {{#if @root.pagination}}
    <nav class="cartanza-pagination">
        {{#if @root.pagination.prev}}
            <a class="newer-posts" href="{{page_url @root.pagination.prev}}"><span aria-hidden="true">&larr;</span> Previous</a>
        {{/if}}
        <span class="page-number">Page {{@root.pagination.page}} of {{@root.pagination.pages}}</span>
        {{#if @root.pagination.next}}
            <a class="older-posts" href="{{page_url @root.pagination.next}}">Next <span aria-hidden="true">&rarr;</span></a>
        {{/if}}
    </nav>
    {{/if}}

    <style>
    .cartanza-pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        margin: 40px auto;
        max-width: var(--container-width);
        padding: 0 20px;
    }
    .cartanza-pagination a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 20px;
        border: 1px solid var(--color-border, #e1e1e1);
        border-radius: 6px;
        color: var(--color-darkgrey, #15171a);
        font-size: 1.4rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
    }
    .cartanza-pagination a:hover {
        border-color: var(--ghost-accent-color, #15171a);
        color: var(--ghost-accent-color, #15171a);
    }
    .cartanza-pagination .page-number {
        font-size: 1.4rem;
        font-weight: 500;
        color: var(--color-secondary-text, #979797);
    }
    </style>

{{/with}}
{{/inline}}
{{> default}}
